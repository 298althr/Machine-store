# App Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://streichergmbh.com
TRACK_DOMAIN=https://streichergmbh.com

# ---------------------------------------------------------
# DATABASE CONFIGURATION
# ---------------------------------------------------------

# Set DB_TYPE to 'csv' to use local flat-file database (Recommended)
# Set DB_TYPE to 'mysql' to use a traditional relational database
DB_TYPE=csv

# CSV Database Configuration
# These files will live in the /data directory for security
DB_CSV_PATH=data/db
DB_CSV_SEPARATOR=","

# MySQL Configuration (Only used if DB_TYPE=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=streicher
DB_USER=root
DB_PASS=

# ---------------------------------------------------------
# EXTERNAL SERVICES
# ---------------------------------------------------------

# Telegram Integration (For Notifications & Admin Replies)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=your_telegram_user_id_here

# Support & Notifications
SUPPORT_EMAIL=store@streichergmbh.com
SUPPORT_AGENT_NAME="JAMES PARKER"

# Email (SMTP)
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=apikey
MAIL_PASSWORD=your_api_key_here
MAIL_FROM_ADDRESS=store@streichergmbh.com
MAIL_FROM_NAME="Streicher GmbH"

# ---------------------------------------------------------
# SECURITY
# ---------------------------------------------------------

# Session settings
SESSION_NAME=streicher_session
SESSION_LIFETIME=120

# Admin Access
ADMIN_SETUP_KEY=generate_a_long_random_string_here
